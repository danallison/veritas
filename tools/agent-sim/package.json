{
  "name": "veritas-agent-sim",
  "version": "0.1.0",
  "description": "Agent simulator for Veritas common-pool computing protocol",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "demo": "tsx src/index.ts",
    "demo:happy": "tsx src/index.ts --scenario happy-path",
    "demo:disagree": "tsx src/index.ts --scenario disagreement",
    "demo:llm": "tsx src/index.ts --scenario real-llm"
  },
  "dependencies": {
    "tweetnacl": "^1.0.3",
    "@noble/hashes": "^1.3.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "tsx": "^4.7.0",
    "@types/node": "^20.0.0"
  }
}
